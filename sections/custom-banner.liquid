<!-- =============================================
   CUSTOM BANNER SECTION
   Structure:
   1. Top Bar       → logo | tagline | CTA button
   2. Hero Area     → background image + text overlay
   3. Marquee Bar   → scrolling text
============================================= -->

<!-- 1. TOP BAR -->
<div class="cb-topbar">
  <!-- Hamburger menu icon (mobile only) -->
  <button class="cb-topbar__menu" aria-label="Open menu" type="button">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <div class="cb-topbar__logo">{{ section.settings.logo_text }}</div>
  <div class="cb-topbar__tagline">{{ section.settings.tagline }}</div>

  <a href="{{ section.settings.cta_url }}" class="cb-topbar__cta">
    {{ section.settings.cta_text }} &rarr;
  </a>
</div>

<!-- 2. HERO AREA -->
<div class="cb-hero">

  <!-- Desktop/Laptop only: bg-1 full width top row -->
  <div class="cb-hero__top">
    <img class="cb-hero__top-img" src="{{ 'bg-1.png' | asset_url }}" alt="" loading="eager">
  </div>

  <!-- Desktop/Laptop: text left | bg-2 right -->
  <div class="cb-hero__bottom">

    <div class="cb-hero__overlay">
      <h1 class="cb-hero__heading">{{ section.settings.hero_heading }}</h1>
      <p class="cb-hero__description">{{ section.settings.hero_description }}</p>
      <a href="{{ section.settings.shop_btn_url }}" class="cb-hero__btn">
        {{ section.settings.shop_btn_text }} &rarr;
      </a>
    </div>

    <div class="cb-hero__bg-col">
      <img class="cb-hero__bg" src="{{ 'bg-2.png' | asset_url }}" alt="" loading="eager">
    </div>

  </div>

  <!-- Mobile only: bg-3 full width with Shop Now button -->
  <div class="cb-hero__mobile">
    <div class="cb-hero__mobile-text">
      <h1 class="cb-hero__heading">{{ section.settings.hero_heading }}</h1>
      <p class="cb-hero__description">{{ section.settings.hero_description }}</p>
    </div>
    <div class="cb-hero__mobile-img-wrap">
      <img class="cb-hero__mobile-img" src="{{ 'bg-3.png' | asset_url }}" alt="" loading="eager">
      <a href="{{ section.settings.shop_btn_url }}" class="cb-hero__btn cb-hero__btn--mobile">
        {{ section.settings.shop_btn_text }} &rarr;
      </a>
    </div>
  </div>

</div>

<!-- 3. MARQUEE BAR -->
<div class="cb-marquee">
  <div class="cb-marquee__track">
    <span>{{ section.settings.marquee_text }}</span>
    <span>{{ section.settings.marquee_text }}</span>
  </div>
</div>

{% stylesheet %}

/* =============================================
   1. TOP BAR
============================================= */
.cb-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 24px;
  background: #fff;
  border-bottom: 1px solid #e0e0e0;
  font-family: 'Arial', sans-serif;
}

.cb-topbar__logo {
  font-size: 18px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #111;
}

.cb-topbar__tagline {
  font-size: 14px;
  color: #111;
  text-align: center;
  flex: 1;
  padding: 0 24px;
}

.cb-topbar__cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #f5e642;
  color: #111;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 12px 24px;
  border: none;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: gap 0.3s ease, color 0.3s ease;
  z-index: 0;
}

/* sweep layer slides in from left */
.cb-topbar__cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: #111;
  transform: translateX(-100%);
  transition: transform 0.35s ease;
  z-index: -1;
}

.cb-topbar__cta:hover::before {
  transform: translateX(0);
}

.cb-topbar__cta:hover {
  gap: 18px;
  color: #fff;
}

/* =============================================
   2. HERO AREA
   Desktop/Laptop: bg-1 top row + text|bg-2 bottom row
   Mobile: bg-3 full width with overlay text + Shop Now btn
============================================= */

/* Mobile block hidden on desktop */
.cb-hero__mobile {
  display: none;
}

/* Hamburger menu button — hidden on desktop */
.cb-topbar__menu {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  flex-shrink: 0;
}

.cb-topbar__menu span {
  display: block;
  width: 22px;
  height: 2px;
  background: #111;
  border-radius: 2px;
}
.cb-hero {
  width: 100%;
  background: #fff;
  overflow: hidden;
}

/* Row 1 — bg-1 full width */
.cb-hero__top {
  width: 100%;
  line-height: 0;
}

.cb-hero__top-img {
  width: 100%;
  display: block;
  object-fit: cover;
  object-position: center top;
  max-height: 320px;
}

/* Row 2 — text + bg-2 side by side */
.cb-hero__bottom {
  display: grid;
  grid-template-columns: 35% 65%;
}

/* Left: text content */
.cb-hero__overlay {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 32px 32px 24px 32px;
  background: #fff;
}

/* Right: bg-2 image */
.cb-hero__bg-col {
  overflow: hidden;
  line-height: 0;
}

.cb-hero__bg {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.cb-hero__heading {
  font-family: 'Jost', sans-serif;
  font-size: clamp(28px, 4.5vw, 70px);
  font-weight: 600;
  color: #111;
  line-height: 100%;
  letter-spacing: 0;
  margin: 0 0 16px 0;
  display: block;
  white-space: nowrap;
}

.cb-hero__description {
  font-family: 'Jost', sans-serif;
  font-size: 15px;
  font-weight: 400;
  line-height: 1.6;
  letter-spacing: 0;
  color: #000;
  margin: 0 0 28px 0;
  max-width: 300px;
}

.cb-hero__btn {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: #111;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 16px 28px;
  position: relative;
  overflow: hidden;
  transition: gap 0.3s ease, color 0.3s ease;
  width: fit-content;
  z-index: 0;
}

/* sweep layer slides in from left */
.cb-hero__btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: #f5e642;
  transform: translateX(-100%);
  transition: transform 0.35s ease;
  z-index: -1;
}

.cb-hero__btn:hover::before {
  transform: translateX(0);
}

.cb-hero__btn:hover {
  gap: 22px;
  color: #111;
}

/* =============================================
   3. MARQUEE BAR — continuously scrolling text
============================================= */
@keyframes cb-marquee-scroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.cb-marquee {
  background: #F5F5F5;
  padding: 14px 0;
  overflow: hidden;
  white-space: nowrap;
}

/* Track holds 2 copies of the text so scroll loops seamlessly */
.cb-marquee__track {
  display: inline-flex;
  animation: cb-marquee-scroll 18s linear infinite;
  will-change: transform;
}

.cb-marquee__track span {
  font-size: clamp(10px, 2.2vw, 13px);
  font-weight: 600;
  letter-spacing: clamp(1px, 0.3vw, 2px);
  text-transform: uppercase;
  color: #111;
  white-space: nowrap;
  /* separator between repeated text */
  padding: 0 48px;
}

/* Pause on hover */
.cb-marquee:hover .cb-marquee__track {
  animation-play-state: paused;
}

/* =============================================
   RESPONSIVE
============================================= */

/* Laptop — 1025px to 1280px */
@media (max-width: 1280px) {
  .cb-hero__bottom {
    grid-template-columns: 38% 62%;
  }

  .cb-hero__heading {
    font-size: 40px;
  }

  .cb-hero__description {
    font-size: 18px;
  }

  .cb-hero__top-img {
    max-height: 280px;
  }

  .cb-hero__overlay {
    padding: 32px 32px 40px;
  }
}

/* Tablet — 768px to 1024px */
@media (max-width: 1024px) {
  .cb-hero__bottom {
    grid-template-columns: 40% 60%;
  }

  .cb-hero__heading {
    font-size: 32px;
  }

  .cb-hero__description {
    font-size: 15px;
  }

  .cb-hero__top-img {
    max-height: 220px;
  }

  .cb-hero__overlay {
    padding: 24px 24px 32px;
  }

  .cb-topbar__tagline {
    font-size: 12px;
  }
}

/* Mobile — below 768px */
@media (max-width: 767px) {
  /* Top bar: menu icon left | logo center | nothing right */
  .cb-topbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 14px 16px;
    gap: 0;
  }

  /* Show hamburger on mobile */
  .cb-topbar__menu {
    display: flex;
    justify-self: start;
  }

  /* Logo centered in middle column */
  .cb-topbar__logo {
    grid-column: 2;
    text-align: center;
  }

  /* Hide tagline + CTA on mobile */
  .cb-topbar__tagline,
  .cb-topbar__cta {
    display: none;
  }

  /* Hide desktop blocks on mobile */
  .cb-hero__top,
  .cb-hero__bottom {
    display: none;
  }

  /* Show mobile-only block */
  .cb-hero__mobile {
    display: flex;
    flex-direction: column;
  }

  /* Text: centered, white background */
  .cb-hero__mobile-text {
    text-align: center;
    padding: 32px 24px 20px;
    background: #fff;
  }

  .cb-hero__heading {
    font-size: 32px;
    white-space: normal;
    margin-bottom: 12px;
  }

  .cb-hero__description {
    font-size: 14px;
    max-width: 100%;
    margin-bottom: 0;
  }

  /* bg-3 image wrapper — relative so btn can sit on top */
  .cb-hero__mobile-img-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* bg-3: full natural size, no crop */
  .cb-hero__mobile-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Shop Now overlaid on bg-3 — slightly above bottom */
  .cb-hero__btn--mobile {
    position: absolute;
    bottom: 48px;
    left: 24px;
    right: 24px;
    width: auto;
    justify-content: center;
    font-size: 12px;
    padding: 16px 20px;
    z-index: 2;
  }

  /* marquee font handled by clamp() globally */
}

{% endstylesheet %}

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "header",
      "content": "Top Bar"
    },
    {
